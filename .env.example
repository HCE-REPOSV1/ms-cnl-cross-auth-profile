# ms-cnl-cross-auth-profile — MS Canal -- Auth Profile
# Generated by Jarvis Platform
# Copiar a .env y completar los valores marcados con ***

# ── Servidor ──────────────────────────────────────────────
PORT=10701
NODE_ENV=development

# ── Cookie ────────────────────────────────────────────────
# true  → cookie solo se envía por HTTPS (producción)
# false → cookie también se envía por HTTP (desarrollo)
COOKIE_SECURE=false

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=***REPLACE_WITH_32_CHAR_SECRET***
JWT_EXPIRES_IN=4h

# ── Servicio MAC (autenticación externa) ──────────────────
# URL base del servicio MAC — sin barra final
EXTERNAL_AUTH_BASE_URL=https://mac.intranet.local/api
# Código de sistema registrado en MAC (consultar al equipo MAC)
EXTERNAL_AUTH_SISTEMA=25
# Timeout en ms para llamadas al servicio MAC
EXTERNAL_AUTH_TIMEOUT_MS=5000
# false → acepta certificados autofirmados o de CA interna
SSL_VERIFY=true

# ── Encriptación MAC ──────────────────────────────────────
# AES-256-CBC compatible con Criptography.Encrypt() del sistema HCE .NET
# CRYPTO_KEY: exactamente 32 caracteres UTF-8
# CRYPTO_IV:  exactamente 16 caracteres UTF-8
CRYPTO_KEY=***REPLACE_WITH_32_CHAR_KEY****
CRYPTO_IV=***REPLACE_16_CHAR**

# ── Kafka Audit Logger ────────────────────────────────────
# AUDIT_LOGGER_ENABLED=false desactiva el audit logger por completo:
# no se intenta conectar a Kafka y el logging se vuelve un no-op silencioso.
# Default: true (si no se define, el audit logger queda habilitado).
AUDIT_LOGGER_ENABLED=true
# Broker(s) Kafka separados por coma
KAFKA_BROKER=localhost:9092
# Topic al que este servicio publica eventos de auditoría
KAFKA_TOPIC=platform.logs
